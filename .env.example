# Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment: dev or prod
ENV=dev
DEBUG=true

# Tushare Pro API
TUSHARE_TOKEN=your_tushare_pro_token_here

# Database
DB_PATH=data/quant_system.db

# LLM Configuration (for Phase 4)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=qwen2

# Data Pipeline
MAX_RETRIES=5
RETRY_BACKOFF_FACTOR=2
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/